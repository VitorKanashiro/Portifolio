# .htaccess — URLs amigáveis e otimizações de performance

# Impede a listagem de diretórios globalmente
Options -Indexes


<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /portifolio-1/

    # URL amigável do projeto: /projeto/nome-do-projeto-1 → projeto.php?slug=nome-do-projeto-1
    RewriteRule ^projeto/([a-z0-9-]+)/?$ projeto.php?slug=$1 [L,QSA]
</IfModule>

# Compressão GZIP para melhor performance
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css text/javascript application/javascript application/json image/svg+xml
</IfModule>

# Cache de arquivos estáticos
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpeg "access plus 1 month"
    ExpiresByType image/png "access plus 1 month"
    ExpiresByType image/webp "access plus 1 month"
    ExpiresByType text/css "access plus 1 week"
    ExpiresByType application/javascript "access plus 1 week"
</IfModule>
