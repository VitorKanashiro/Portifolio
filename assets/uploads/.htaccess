# Impede a execução de scripts PHP e outros executáveis na pasta de uploads
<FilesMatch "\.(php|php3|php4|php5|php7|php8|phtml|pl|py|jsp|asp|sh|cgi)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order Deny,Allow
        Deny from all
    </IfModule>
</FilesMatch>

# Desabilita listagem de diretório e execução de CGI
Options -Indexes -ExecCGI
